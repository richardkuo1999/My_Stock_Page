# Analysis Bot 環境變數範例
# 複製此檔為 .env 並填入實際值

APP_NAME="My Stock Analysis Bot"
DEBUG=True

# Database
DATABASE_URL="sqlite:///./stock_data.db"

# Telegram（必填）
TELEGRAM_TOKEN=your_bot_token

# Threads 監控 → Telegram（scripts/threads_telegram_watch.py，選填）
# THREADS_USERNAME=some_user
# THREADS_TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Bot 內 /threads 定時輪詢間隔（秒）；0 = 僅手動 /threads check
# THREADS_WATCH_INTERVAL_SEC=900

# Telegram 允許的 Agent 使用者 ID（選填）
# TELEGRAM_AGENT_ALLOWED_USER_IDS=["123456789"]

# Financial Data
# FINMIND_TOKENS 支援 JSON 陣列，可填多組 token 輪替
FINMIND_TOKENS='["your_finmind_token"]'
NEWS_API_KEY=your_news_api_key

# 富果行情 REST API（選填）https://developer.fugle.tw/
# FUGLE_API_KEY=

# News Source Toggles
ENABLE_UDN_NEWS=false
ENABLE_YAHOO_NEWS=false

# AI Keys
GEMINI_API_KEYS='["your_gemini_key"]'
GROQ_API_KEY=your_groq_key

# AI Provider: "ollama" 或 "gemini"
AI_PROVIDER=ollama

# Ollama（雲端：https://ollama.com，本機：http://localhost:11434）
OLLAMA_BASE_URL="https://ollama.com"
OLLAMA_MODEL="glm-5:cloud"
OLLAMA_API_KEY=your_ollama_api_key

# Logging / Privacy
LOG_PII_SALT=

# 爆量偵測：第 1 檔題材／新聞＋ AI（預設關閉；enrich_with_news 仍保留於程式）
# SPIKE_NEWS_ENRICHMENT_ENABLED=false

# Parallel Analysis
MAX_CONCURRENT_ANALYSIS=10
ANALYSIS_PROGRESS_INTERVAL=50
ANALYSIS_BATCH_SIZE=100

# UAnalyze / MEGA（機密，請在 .env 中填入）
# UANALYZE_AI_URL_TEMPLATE=
# UANALYZE_API_URL=
# UANALYZE_KEYWORDS=
# TELEGRAM_AI_NEWS_CHAT_ID=
# TELEGRAM_AI_NEWS_TOPIC_ID=
# MEGA_PUBLIC_URL=

# 元大投顧（選填，用於 scripts/yuanta_report_downloader.py）
# YT_ACCOUNT=your_account
# YT_PASSWORD=your_password

# Google Sheets 自選股同步（選填）
# 試算表需為公開或「知道連結的人可檢視」
# 用戶透過 /gsheet add <URL> 在 Telegram 中註冊，不需在此設定
